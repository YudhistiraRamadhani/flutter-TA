import 'package:firebase_core/firebase_core.dart';
import 'package:firebase_messaging/firebase_messaging.dart';
import 'package:flutter/material.dart';
import 'package:flutter_application_1/lib/Dashboard.dart';


// Fungsi global untuk menangani notifikasi saat aplikasi mati / di background
Future<void> _firebaseMessagingBackgroundHandler(RemoteMessage message) async {
  // Pastikan core firebase terinisialisasi ulang di proses background terpisah ini
  await Firebase.initializeApp();
  print("Notifikasi masuk di Background/Terminated: ${message.notification?.title}");
}

void main() async {
  WidgetsFlutterBinding.ensureInitialized();
  
  // 1. Inisialisasi Firebase
  await Firebase.initializeApp();

  // 2. Set handler untuk background/terminated state
  FirebaseMessaging.onBackgroundMessage(_firebaseMessagingBackgroundHandler);

  runApp(const MyApp());
}

class MyApp extends StatefulWidget {
  const MyApp({super.key});

  @override
  State<MyApp> createState() => _MyAppState();
}

class _MyAppState extends State<MyApp> {
  @override
  void initState() {
    super.initState();
    _setupNotificationSettings();
  }

  void _setupNotificationSettings() async {
    FirebaseMessaging messaging = FirebaseMessaging.instance;

    // 1. Meminta izin notifikasi (Sangat penting untuk iOS & Android 13 ke atas)
    NotificationSettings settings = await messaging.requestPermission(
      alert: true,
      badge: true,
      sound: true,
    );

    if (settings.authorizationStatus == AuthorizationStatus.authorized) {
      print('Izin notifikasi diberikan oleh pengguna.');

      // 2. SUBSCRIBE KE TOPIK 'all_users'
      // Ini harus sama persis dengan string 'topic' yang kita ketik di backend Laravel!
      await messaging.subscribeToTopic('all_users');
      print('Berhasil terhubung ke topik: all_users');

      // 3. Menangani notifikasi yang masuk saat aplikasi sedang menyala (Foreground)
      FirebaseMessaging.onMessage.listen((RemoteMessage message) {
        print('Notifikasi masuk di Foreground (Aplikasi sedang dibuka)!');
        if (message.notification != null) {
          // Jika aplikasi sedang dibuka, Anda bisa menampilkan dialog kustom, snackbar, atau snackbar internal
          showDialog(
            context: context,
            builder: (context) => AlertDialog(
              title: Text(message.notification!.title ?? 'Pengingat'),
              content: Text(message.notification!.body ?? ''),
              actions: [
                TextButton(
                  onPressed: () => Navigator.pop(context),
                  child: const Text('OK'),
                )
              ],
            ),
          );
        }
      });
    } else {
      print('Izin notifikasi ditolak oleh pengguna.');
    }
  }

  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      debugShowCheckedModeBanner: false,
      home: Scaffold(
        appBar: AppBar(
          title: const Text('Aplikasi Pembukuan Keuangan'),
          backgroundColor: Colors.blueAccent,
        ),
        body: const Center(
          child: Text(
            'Sistem Siap Menerima Notifikasi Jam 9 Malam',
            style: TextStyle(fontSize: 16, fontWeight: FontWeight.w500),
          ),
        ),
      ),
    );
  }
}