import 'dart:convert';
import 'package:http/http.dart' as http;
import 'package:flutter_application_1/model/postdatapiutang.dart';

class Apidatapiutang {
  final String baseUrl = 'http://192.168.1.4:8000/api/piutang';
  final String apiToken = "1|fl4Xog5gUWR78vc40UDWAXGppHppCMPPXKpOd8sPeea9f88e";
  
  // 1. Ambil Semua Data
  Future<List<dynamic>> getdatapiutang() async {
    try {
      final response = await http.get(
        Uri.parse(baseUrl),
        headers: {
          "Accept": "application/json",
          "Authorization": "Bearer $apiToken",
        },
      );
print("Respon Server: ${response.body}");
      if (response.statusCode == 200) {
        return jsonDecode(response.body);
      } else {
        print("Server error: ${response.statusCode}");
        return [];
      }
    } catch (e) {
      print("Error koneksi: $e");
      return [];
    }
  }


  Future<bool> updateStatusLunas(dynamic id) async {
    try {
      final response = await http.put(
        Uri.parse('$baseUrl/$id'), // Mengarah ke route update laravel: api/piutang/{id}
        headers: {
          "Content-Type": "application/json",
          "Accept": "application/json",
          "Authorization": "Bearer $apiToken",
        },
        body: jsonEncode({
          "status": "Lunas", // Data yang ingin diubah
        }),
      );

      if (response.statusCode == 200) {
        return true;
      } else {
      
        print("Server error ${response.statusCode}: ${response.body}");
        return false;
      }
    } catch (e) {
      print("Error koneksi saat update: $e");
      return false;
    }
  }

  // 3. Tambah Data Baru
  // Di dalam class Apidatapiutang
Future<bool> insertdatapiutang(
    String nama_pelanggan,
    int jumlah_hutang,
    String nama_barang,
    int harga,
    String status,
    String no_whatsapp, // Parameter menggunakan nama no_whatsapp
  ) async {
    final response = await http.post(
      Uri.parse(baseUrl),
      headers: {
        "Content-Type": "application/json",
        "Accept": "application/json",
        "Authorization": "Bearer $apiToken",
      },
      body: jsonEncode({
        "nama_pelanggan": nama_pelanggan,
        "jumlah_hutang": jumlah_hutang,
        "nama_barang": nama_barang,
        "harga": harga,
        "status": status,
        "no_whatsapp": no_whatsapp // Mengirim data whatsapp ke kolom no_whatsapp di tabel piutang
      }),
    );
    return response.statusCode == 200 || response.statusCode == 201;
  }

  // 4. Fetch dengan Pagination (Existing)
  Future<Map<String, dynamic>> fetchTransaksi(int page) async {
    try {
      final response = await http.get(
        Uri.parse('$baseUrl?page=$page'),
        headers: {
          "Accept": "application/json",
          "Authorization": "Bearer $apiToken",
        },
      );

      if (response.statusCode == 200) {
        final data = json.decode(response.body);
        var listData = data['data'] is List ? data['data'] : data['data']['data'];

        List<Postdatapiutang> datapiutang = (listData as List)
            .map((json) => Postdatapiutang.fromJson(json))
            .toList();

        return {
          'datapiutang': datapiutang,
          'nextPageUrl': data['data']?['next_page_url'] ?? data['next_page_url'],
        };
      } else {
        throw Exception('Gagal memuat data: ${response.statusCode}');
      }
    } catch (e) {
      throw Exception('Terjadi kesalahan: $e');
    }
  }
  Future<bool> updatePiutang(String id, Map<String, dynamic> data) async {
    try {
      final response = await http.put(
        Uri.parse("$baseUrl/$id"), // Hapus kata /piutang di sini karena sudah ada di baseUrl
        headers: {
          "Content-Type": "application/json",
          "Accept": "application/json",
          "Authorization": "Bearer $apiToken", // Tambahkan token jika Laravel menggunakan middleware auth
        },
        body: jsonEncode(data),
      );
      
      if (response.statusCode != 200) {
        print("Update Gagal: ${response.body}");
      }
      return response.statusCode == 200;
    } catch (e) {
      print("Error Update: $e");
      return false;
    }
  }

  // 3. Fungsi Delete
  Future<bool> deletePiutang(String id) async {
    try {
      final response = await http.delete(
        Uri.parse("$baseUrl/$id"), // Hapus kata /piutang di sini
        headers: {
          "Accept": "application/json",
          "Authorization": "Bearer $apiToken",
        },
      );
      return response.statusCode == 200;
    } catch (e) {
      return false;
    }
  }

 
  
}