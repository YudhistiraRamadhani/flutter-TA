                                //     'Pemasukan - Pengeluaran', 
                                //     Colors.blue
                                //   ),
                                // ),
                                // const SizedBox(width: 12),
                                Expanded(
                                  child: _buildDashboardCard(
                                    'Stok Barang', 
                                    totalProdukText, 
                                    'Jumlah Seluruh Produk', 
                                    Colors.orange
                                  ),
                                ),
                              ],
                            ),
                          ),
                          // HALAMAN 3: TOTAL PIUTANG (Menampilkan Jumlah Kasus Transaksi)
                          Padding(
  padding: const EdgeInsets.symmetric(horizontal: 24),
  child: Center(
    child: SizedBox(
      width: MediaQuery.of(context).size.width * 0.4, // 60% dari lebar layar
      child: _buildDashboardCard(
        'Total Piutang', 
